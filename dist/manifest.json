{
  "manifest_version": 3,
  "name": "Stealth Lightbeacon (Addon Lite)",
  "version": "0.1.9",
  "description": "Browser-only DOM audit + limited same-origin crawl scanner",
  "icons": {
    "16": "extension_icon16.png",
    "32": "extension_icon32.png",
    "48": "extension_icon48.png",
    "128": "extension_icon128.png"
  },
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [],
  "action": {
    "default_title": "Stealth Lightbeacon",
    "default_icon": {
      "16": "icons/icon-normal-16.png",
      "32": "icons/icon-normal-32.png",
      "48": "icons/icon-normal-48.png",
      "64": "icons/icon-normal-64.png",
      "128": "icons/icon-normal-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  }
}
