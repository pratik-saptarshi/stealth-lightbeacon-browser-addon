{
  "manifest_version": 3,
  "name": "Stealth Lightbeacon (Addon Lite)",
  "version": "0.1.3",
  "description": "Browser-only DOM audit + limited same-origin crawl scanner",
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [],
  "action": {
    "default_title": "Stealth Lightbeacon"
  }
}
